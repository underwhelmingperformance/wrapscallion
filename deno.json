{
	"name": "@underwhelmingperformance/wrapscallion",
	"version": "0.2.1",
	"license": "MIT",
	"exports": {
		".": "./src/main.ts"
	},
	"imports": {
		"@commitlint/config-conventional": "npm:@commitlint/config-conventional@21.2.0",
		"@commitlint/lint": "npm:@commitlint/lint@21.2.0",
		"@cto.af/linewrap": "npm:@cto.af/linewrap@4.0.1",
		"@cto.af/string-width": "npm:@cto.af/string-width@5.0.1",
		"@std/assert": "jsr:@std/assert@1.0.19",
		"@std/cli/unstable-spinner": "jsr:@std/cli@1.0.30/unstable-spinner",
		"@std/toml": "jsr:@std/toml@1.0.11",
		"commander": "npm:commander@15.0.0",
		"conventional-changelog-conventionalcommits": "npm:conventional-changelog-conventionalcommits@9.3.1",
		"diff": "npm:diff@9.0.0",
		"just-git": "npm:just-git@1.7.1",
		"markdownlint": "npm:markdownlint@0.40.0",
		"markdownlint/promise": "npm:markdownlint@0.40.0/promise",
		"micromark": "npm:micromark@4.0.2",
		"micromark-extension-gfm": "npm:micromark-extension-gfm@3.0.0",
		"picocolors": "npm:picocolors@1.1.1",
		"re2js": "npm:re2js@2.8.3"
	},
	"nodeModulesDir": "auto",
	"tasks": {
		"wrapscallion": "deno run --allow-read --allow-write --allow-env src/main.ts",
		"build": "deno compile --allow-read --allow-write --allow-env --output dist/wrapscallion src/main.ts",
		"check": "deno task check:format && deno task check:lint && deno task check:types && deno task check:test",
		"check:format": "deno fmt --check",
		"check:lint": "deno lint",
		"check:test": "deno test --ignore-env --allow-read --allow-write",
		"check:types": "deno check src/main.ts src/*.test.ts",
		"fix": "deno fmt"
	},
	"fmt": {
		"useTabs": true,
		"singleQuote": true,
		"proseWrap": "always",
		"exclude": [
			"dist",
			"node_modules",
			"CHANGELOG.md"
		]
	},
	"lint": {
		"exclude": [
			"dist",
			"node_modules"
		],
		"rules": {
			"tags": [
				"recommended"
			]
		}
	},
	"compilerOptions": {
		"lib": [
			"ES2023",
			"DOM",
			"DOM.Iterable",
			"deno.ns"
		],
		"strict": true,
		"noUncheckedIndexedAccess": true
	}
}
